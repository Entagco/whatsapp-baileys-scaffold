# Base URL of your Baileys bridge service (the Node.js process that holds
# the actual WhatsApp Web session and exposes a /send endpoint).
BAILEYS_URL=http://localhost:3000

# Shared secret this backend and your Baileys bridge both check on every
# request. Generate a long random value, e.g.: openssl rand -hex 32
INTERNAL_SECRET=your_shared_secret_here

# When true, no messages are actually sent — they're printed to stdout
# instead. Useful for local development.
DRY_RUN=false
